{
  "name": "@seven-auto/libs",
  "version": "0.0.0",
  "private": true,
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "node": "./dist/index.js",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "build": "tsc -p tsconfig.json",
    "check-types": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "test": "jest --config jest.config.cjs",
    "test:watch": "jest --config jest.config.cjs --watch",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "devDependencies": {
    "@seven-auto/eslint-config": "workspace:*",
    "@seven-auto/typescript-config": "workspace:*",
    "@types/crypto-js": "^4.2.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.2",
    "@types/numeral": "^2.0.5",
    "eslint": "^9.39.1",
    "jest": "^30.4.2",
    "ts-jest": "^29.2.5",
    "typescript": "5.9.2"
  },
  "dependencies": {
    "axios": "^1.9.0",
    "crypto-js": "^4.2.0",
    "numeral": "^2.0.6"
  }
}
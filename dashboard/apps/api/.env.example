# Copy to .env and set real values. API validates all keys at startup (see src/modules/env/env.service.ts).

# App
APP_NODE_ENV=development
APP_NAME=SevenAuto API
API_URL=http://localhost:4000
BASE_URL=http://localhost:3000
ASSETS_URL=http://localhost:3000
SERVER_IP=127.0.0.1
PORT=4000
API_VERSION=v1

APP_SECRET=change-me-app-secret
APP_SERVICE_SECRET=change-me-service-secret

# Tokens (seconds or your convention — must be numeric)
ACCESS_TOKEN_EXPIRE_TIME=3600
REFRESH_TOKEN_EXPIRE_TIME=604800
VERIFY_TOKEN_EXPIRE_TIME=86400

# Flags
PRISMA_LOG=false
GOOGLE_LOG=false
GOOGLE_LOG_NAME=sevenauto-api
GOOGLE_PROJECT_ID=local-dev

# Swagger (/v1/docs when API_VERSION=v1)
SWAGGER_OPEN=true
SWAGGER_LOCKED=false
SWAGGER_USER=admin
SWAGGER_PASSWORD=change-me

# Database (Prisma + MySQL fields both required by validator)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=sevenauto
MYSQL_USER=sevenauto
MYSQL_PASSWORD=sevenauto
DATABASE_URL=mysql://sevenauto:sevenauto@localhost:3306/sevenauto

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL_PREFIX=sevenauto:

# S3-compatible storage
S3_ENDPOINT=http://localhost:9000
S3_API_VERSION=2006-03-01
S3_ACCESSKEYID=minio
S3_SECRETACCESSKEY=minio123
S3_REGION=us-east-1
S3_BUCKET=sevenauto
S3_PREFIX=uploads/

MEDIA_SECRET=change-me-media-secret
MEDIA_ALLOWED_VIDEO=false
MEDIA_ALLOWED_FILE=true
MEDIA_UPLOAD_PREFIX=media/

# Email (set EMAIL_ENABLED=false to skip sending in dev)
EMAIL_ENABLED=false
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_USER=
EMAIL_PASS=
EMAIL_NAME=SevenAuto
EMAIL_REPLY=noreply@example.com
EMAIL_SECURE=false

# Queue UI (e.g. Bull Board path — adjust to your setup)
QUEUES_PORT=3001
QUEUES_PATH=/queues
QUEUES_LOCKED=false
QUEUES_USER=admin
QUEUES_PASSWORD=change-me
